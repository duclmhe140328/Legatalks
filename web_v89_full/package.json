{
  "name": "nexora-connect",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n SERVER,WEB -c auto \"npm run dev -w apps/server\" \"npm run dev -w apps/web\"",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/server",
    "seed": "npm run seed -w apps/server",
    "test": "npm run test -w apps/server",
    "seed:reset": "npm run seed:reset -w apps/server"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
