  :root {
    --top-nav-height: 52px;
  }

  body {
    padding-bottom: 64px;
  }

  .fb-top-nav {
    height: var(--top-nav-height);
    padding: 0 8px;
  }

  .fb-logo {
    width: 38px;
    height: 38px;
  }

  .fb-global-search {
    width: 42px;
    height: 40px;
    justify-content: center;
    padding: 0;
  }

  .fb-global-search input {
    display: none;
  }

  .fb-top-actions {
    gap: 5px;
  }

  .fb-circle-action,
  .fb-avatar-button,
  .fb-mobile-menu {
    width: 38px;
    height: 38px;
  }

  .fb-mobile-bottom-nav {
    position: fixed;
    z-index: 1100;
    right: 0;
    bottom: 0;
    left: 0;
    height: calc(62px + env(safe-area-inset-bottom));
    padding: 5px 4px env(safe-area-inset-bottom);
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border-top: 1px solid var(--fb-line);
    background: #fff;
    box-shadow: 0 -1px 5px rgba(0, 0, 0, .08);
  }

  .fb-mobile-bottom-nav a {
    position: relative;
    display: grid;
