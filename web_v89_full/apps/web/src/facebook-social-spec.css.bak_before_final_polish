/* =========================================================
   WEB UI SYNC FIX - light comments, header social tabs,
   wide groups/livestream, inline quick chat, mobile polish
========================================================= */

.fb-top-tabs-social {
  max-width: min(920px, 100%);
  gap: 6px;
}

.fb-top-tabs-social a {
  min-width: 0;
  padding: 8px 14px !important;
  border-radius: 12px !important;
}

.fb-top-tabs-social a span {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2px;
  text-align: left;
  line-height: 1.12;
}

.fb-top-tabs-social a span strong {
  font-size: 15px;
  font-weight: 700;
  color: var(--fb-text);
}

.fb-top-tabs-social a span small {
  display: block;
  font-size: 11px;
  color: var(--fb-muted);
}

.fb-top-tabs-social a.active {
  background: var(--fb-soft-blue) !important;
  color: var(--fb-blue) !important;
}

.fb-top-tabs-social a.active span strong,
.fb-top-tabs-social a.active span small {
  color: var(--fb-blue) !important;
}

/* Hide duplicated in-page tab bar because these tabs are moved to header */
.timeline-shell .timeline-tabbar-wrap,
.timeline-page .timeline-tabbar-wrap,
.timeline-shell .timeline-tabs,
.timeline-page .timeline-tabs {
  display: none !important;
}

/* Force light comments */
.post-card .comments-thread,
.post-card .comment-thread,
.post-card .comment-list,
.post-card .post-comments,
.post-card .comments-panel,
.post-card .comment-panel,
.post-card .comment-area,
.post-card .comment-section,
.post-card .comment-section-inner,
.video-journal-layout .comments-thread,
.video-journal-layout .comment-list,
.video-journal-layout .comment-panel,
.video-journal-layout .comment-area,
.video-journal-layout .comment-section,
[class*='comment-thread'],
[class*='comment-list'],
[class*='comment-panel'],
[class*='comment-section'] {
  background: #ffffff !important;
  color: var(--fb-text) !important;
}

.comment-item,
.comment-item > div,
.comment-row,
.comment-card,
.comment-bubble,
.reply-bubble,
.reply-item > div,
.reply-item,
.comment-box,
.comment-compose,
.comment-composer,
.comment-input,
.comment-footer,
.video-journal-layout .comment-bubble,
.video-journal-layout .comment-item > div {
  background: #fff !important;
  color: var(--fb-text) !important;
}

.comment-item h4,
.comment-item strong,
.comment-bubble strong,
.comment-bubble h4,
.comment-item p,
.comment-bubble p,
.comment-item small,
.comment-bubble small,
.comment-item span,
.comment-bubble span,
.reply-item p,
.reply-item span,
.reply-item small {
  color: var(--fb-text) !important;
  opacity: 1 !important;
}

.comment-box input,
.comment-composer input,
.comment-composer textarea,
.comment-compose input,
.comment-compose textarea,
.comment-input input,
.comment-input textarea,
.video-journal-layout .comment-composer input,
.video-journal-layout .comment-composer textarea {
  border: 1px solid var(--fb-line) !important;
  border-radius: 999px !important;
  background: #f0f2f5 !important;
  color: var(--fb-text) !important;
}

.comment-actions button,
.comment-send-btn,
.comment-icon-btn,
.comment-tools button {
  color: var(--fb-muted) !important;
  background: transparent !important;
}

/* Video full display similar TikTok full-fit */
.video-journal-layout .video-card,
.video-journal-layout .post-card,
.video-journal-layout .video-stage,
.video-journal-layout .post-media,
.post-card .post-media,
.post-card .video-player-wrap,
.post-card .media-frame {
