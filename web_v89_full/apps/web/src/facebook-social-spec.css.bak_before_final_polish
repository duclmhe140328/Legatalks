  max-height: min(82svh, 920px) !important;
  object-fit: contain !important;
  margin: 0 auto !important;
  background: #000 !important;
}

/* Full width for groups and livestream pages */
.timeline-wide-body.with-left,
.timeline-wide-body.with-left.with-right {
  grid-template-columns: 280px minmax(0, 1fr) !important;
}

.timeline-wide-shell .fb-main-route,
.timeline-wide-shell .fb-route-view,
.timeline-wide-shell .timeline-route-view,
.timeline-full-route,
.timeline-full-route .timeline-page,
.timeline-full-route .community-groups-page,
.timeline-full-route .live-panel,
.timeline-full-route .video-journal-layout {
  max-width: 100% !important;
  width: 100% !important;
}

.timeline-wide-shell .timeline-page,
.timeline-wide-shell .community-groups-page,
.timeline-wide-shell .live-panel,
.timeline-wide-shell .video-journal-layout {
  max-width: 100% !important;
  margin: 0 !important;
}

.timeline-wide-shell .timeline-side,
.timeline-wide-shell .feed-side,
.timeline-wide-shell .right-aside {
  display: none !important;
}

/* Inline quick chat outside Messenger page */
.fb-quick-chat-rich {
  width: 380px;
  max-width: calc(100vw - 24px);
}

.fb-quick-chat-thread {
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 260px;
  max-height: 360px;
  overflow-y: auto;
  padding: 14px 14px 8px;
  background: #fff;
}

.fb-quick-msg {
  display: flex;
  align-items: flex-end;
  gap: 8px;
}

.fb-quick-msg.mine {
  justify-content: flex-end;
}

.fb-quick-msg.mine .fb-quick-bubble {
  background: var(--fb-blue);
  color: #fff;
  border-radius: 18px 18px 4px 18px;
}

.fb-quick-msg.other .fb-quick-bubble {
  background: #f0f2f5;
  color: var(--fb-text);
  border-radius: 18px 18px 18px 4px;
}

.fb-quick-bubble-wrap {
  max-width: 76%;
}

.fb-quick-bubble {
  padding: 10px 12px;
  font-size: 14px;
  line-height: 1.45;
  word-break: break-word;
}

.fb-quick-chat-composer {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 44px;
  gap: 10px;
  padding: 12px;
  border-top: 1px solid var(--fb-line);
  background: #fff;
}

.fb-quick-chat-composer input {
  min-height: 42px;
  padding: 10px 14px;
  border: 1px solid var(--fb-line) !important;
  border-radius: 999px !important;
  background: #f0f2f5 !important;
}

.fb-quick-chat-composer button {
  border: 0;
  border-radius: 50%;
  background: var(--fb-blue);
  color: #fff;
}

.fb-quick-chat-composer button:disabled {
  opacity: .55;
}

