/* =========================================================
   NEXORA CONNECT - FACEBOOK-STYLE SOCIAL DESIGN SPEC
   Palette and layout follow Thiet_Ke_UI_UX_Mang_Xa_Hoi.pdf
========================================================= */

:root {
  --fb-blue: #1877f2;
  --fb-blue-hover: #166fe5;
  --fb-green: #42b72a;
  --fb-red: #e41e3f;
  --fb-bg: #f0f2f5;
  --fb-card: #ffffff;
  --fb-text: #050505;
  --fb-muted: #65676b;
  --fb-line: #e4e6eb;
  --fb-control: #e4e6eb;
  --fb-soft-blue: #e7f3ff;
  --fb-hover: #f2f2f2;
  --fb-shadow: 0 1px 2px rgba(0, 0, 0, .10);
  --fb-shadow-large: 0 12px 34px rgba(0, 0, 0, .18);
  --top-nav-height: 56px;
  font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  color: var(--fb-text);
  background: var(--fb-bg);
}

html,
body,
#root {
  min-width: 320px;
  min-height: 100%;
  margin: 0;
  background: var(--fb-bg) !important;
  color: var(--fb-text) !important;
  font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif !important;
  -webkit-font-smoothing: antialiased;
}

body {
  overflow-x: hidden;
}

* {
  box-sizing: border-box;
}

button,
input,
textarea,
select {
  font-family: inherit;
}

button {
  color: inherit;
}

img,
video {
  max-width: 100%;
}

::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-thumb {
  border: 2px solid transparent;
  border-radius: 999px;
  background: #bcc0c4;
  background-clip: padding-box;
}

::-webkit-scrollbar-track {
  background: transparent;
}

.card {
  border: 0 !important;
  border-radius: 12px !important;
  background: var(--fb-card) !important;
  color: var(--fb-text) !important;
  box-shadow: var(--fb-shadow) !important;
}

.muted,
.empty-mini,
.section-head p,
[class*="subtitle"] {
  color: var(--fb-muted) !important;
}

.avatar {
  border: 0 !important;
  background: #d8dadf;
}

.avatar-fallback {
  border: 0 !important;
  background: #dbeafe !important;
  color: var(--fb-blue) !important;
}

.primary-btn,
.primary-small,
.publish-btn,
.send-btn,
.soft-btn,
.secondary-btn,
.ghost-danger {
  border-radius: 8px !important;
  box-shadow: none !important;
  font-weight: 700 !important;
}

.primary-btn,
.primary-small,
.publish-btn,
.send-btn {
  border: 0 !important;
  background: var(--fb-blue) !important;
  color: #fff !important;
}

.primary-btn:hover,
.primary-small:hover,
.publish-btn:hover,
.send-btn:hover {
  transform: none !important;
  filter: none !important;
  background: var(--fb-blue-hover) !important;
}

.secondary-btn,
.soft-btn {
  border: 0 !important;
  background: var(--fb-control) !important;
  color: var(--fb-text) !important;
}

.icon-btn {
  border: 0 !important;
  border-radius: 50% !important;
  background: var(--fb-control) !important;
  color: var(--fb-text) !important;
  box-shadow: none !important;
}

.badge,
.nav-unread,
.conversation-unread {
  background: var(--fb-red) !important;
  color: #fff !important;
}

.form-status {
  border: 1px solid #bfdbfe !important;
  border-radius: 8px !important;
  background: #eff6ff !important;
  color: #1d4ed8 !important;
}

input:not([type="checkbox"]):not([type="radio"]),
textarea,
select {
  border-color: #ccd0d5 !important;
  border-radius: 8px !important;
  background: #fff !important;
  color: var(--fb-text) !important;
}

input:not([type="checkbox"]):not([type="radio"]):focus,
textarea:focus,
select:focus {
  border-color: var(--fb-blue) !important;
  box-shadow: 0 0 0 2px rgba(24, 119, 242, .14) !important;
}

input::placeholder,
textarea::placeholder {
  color: #8a8d91 !important;
}

/* =========================================================
   LOGIN / REGISTER
========================================================= */

.nexora-auth,
.nx-auth-page,
.nx-auth-v2,
.auth-page {
  min-height: 100svh !important;
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(360px, 520px) !important;
  overflow: auto !important;
  background: var(--fb-bg) !important;
  color: var(--fb-text) !important;
}

.nexora-auth-left,
.nx-auth-left,
.nx-auth-v2__intro,
.auth-visual {
  min-height: 100svh !important;
  padding: clamp(34px, 6vw, 90px) !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;
  background: transparent !important;
  color: var(--fb-text) !important;
}

.nexora-auth-glow,
.visual-orb,
.auth-visual::after {
  display: none !important;
}

.nexora-auth-brand,
.nx-brand,
.mobile-brand {
  position: absolute !important;
  top: 34px !important;
  left: clamp(34px, 6vw, 90px) !important;
}

.nexora-auth-logo,
.nx-logo,
.nx-auth-v2__logo,
.brand-mark {
  border-radius: 50% !important;
  background: var(--fb-blue) !important;
  color: #fff !important;
  box-shadow: none !important;
}

.nexora-auth-brand h1,
.nexora-auth-hero h2,
.nexora-auth-hero h2 span,
.nx-auth-hero h1,
.nx-hero h1,
.auth-copy h1 {
  background: none !important;
  color: var(--fb-blue) !important;
  -webkit-text-fill-color: initial !important;
}

.nexora-auth-hero h2,
.nx-auth-hero h1,
.nx-hero h1,
.auth-copy h1 {
  max-width: 680px !important;
  margin: 0 0 18px !important;
  font-size: clamp(44px, 5vw, 68px) !important;
  line-height: 1.02 !important;
  letter-spacing: -3px !important;
}

.nexora-auth-hero > p,
.nx-auth-hero > p,
.nx-hero p,
.auth-copy p {
  max-width: 580px !important;
  color: #1c1e21 !important;
  font-size: 22px !important;
  line-height: 1.35 !important;
  font-weight: 400 !important;
}

.nexora-auth-kicker,
.nexora-auth-features,
.nx-auth-features,
.nx-feature-grid,
.feature-pills {
  display: none !important;
}

.nexora-auth-right,
.nx-auth-card-wrap,
.nx-auth-v2__panel,
.auth-panel {
  min-height: 100svh !important;
  padding: 24px !important;
  display: grid !important;
  place-items: center !important;
  border: 0 !important;
  background: transparent !important;
  backdrop-filter: none !important;
}

.nexora-auth-card,
.nx-auth-card,
.nx-auth-v2__card,
.auth-card {
  width: min(100%, 420px) !important;
  padding: 18px !important;
  border: 0 !important;
  border-radius: 10px !important;
  background: #fff !important;
  box-shadow: 0 2px 12px rgba(0, 0, 0, .18) !important;
}

.nexora-auth-title,
.auth-card h2 {
  color: var(--fb-text) !important;
  text-align: center;
}

.nexora-auth-subtitle,
.auth-card > p {
  color: var(--fb-muted) !important;
  text-align: center;
}

.nexora-auth-field input,
.nx-field input,
.auth-card input,
.auth-card select {
  min-height: 52px !important;
  border-radius: 6px !important;
  border-color: #dddfe2 !important;
  font-size: 16px !important;
  font-weight: 400 !important;
}

.nexora-auth-tabs,
.auth-tabs {
  border-radius: 8px !important;
  background: #f0f2f5 !important;
}

.nexora-auth-tab,
.auth-tabs button {
  border-radius: 6px !important;
}

.nexora-auth-tab.active,
.auth-tabs button.active {
  background: var(--fb-blue) !important;
  color: #fff !important;
  box-shadow: none !important;
}

.nexora-auth-btn,
.nx-primary,
.auth-card .primary-btn {
  min-height: 48px !important;
  border-radius: 6px !important;
  background: var(--fb-blue) !important;
  color: #fff !important;
  box-shadow: none !important;
}

.nexora-auth-foot a,
.nx-footer-link a,
.auth-foot a,
.nexora-auth-link-btn,
.nx-ghost {
  color: var(--fb-blue) !important;
}

/* =========================================================
   TOP NAV + THREE-COLUMN APP SHELL
========================================================= */

.fb-shell {
  min-height: 100svh;
  background: var(--fb-bg);
  color: var(--fb-text);
}

.fb-top-nav {
  position: fixed;
  z-index: 1000;
  inset: 0 0 auto;
  height: var(--top-nav-height);
  display: grid;
  grid-template-columns: minmax(250px, 1fr) minmax(360px, 680px) minmax(250px, 1fr);
  align-items: center;
  gap: 12px;
  padding: 0 16px;
  border-bottom: 1px solid #dddfe2;
  background: #fff;
  box-shadow: 0 1px 2px rgba(0, 0, 0, .10);
}

.fb-top-left,
.fb-top-actions,
.fb-top-tabs,
.fb-global-search,
.fb-side-profile,
.fb-contact-row,
.fb-quick-person,
.fb-upcoming-head,
.fb-upcoming-row,
.fb-meeting-quickjoin > div,
.fb-meeting-code-form {
  display: flex;
  align-items: center;
}

.fb-top-left {
  min-width: 0;
  gap: 8px;
}

.fb-logo {
  flex: 0 0 auto;
  width: 40px;
  height: 40px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: var(--fb-blue);
  color: #fff;
  font-size: 24px;
  font-weight: 900;
  line-height: 1;
}

.fb-global-search {
  width: min(100%, 255px);
  min-height: 40px;
  gap: 8px;
  padding: 0 13px;
  border-radius: 999px;
  background: var(--fb-bg);
  color: var(--fb-muted);
}

.fb-global-search input {
  min-width: 0;
  min-height: 0 !important;
  width: 100%;
  padding: 0 !important;
  border: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
  font-size: 15px;
}

.fb-top-tabs {
  align-self: stretch;
  justify-content: center;
  gap: 8px;
}

.fb-top-tabs a {
  position: relative;
  min-width: 112px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border-radius: 8px;
  color: var(--fb-muted);
}

.fb-top-tabs a:hover {
  height: calc(100% - 8px);
  align-self: center;
  background: var(--fb-hover);
}

.fb-top-tabs a.active {
  color: var(--fb-blue);
}

.fb-top-tabs a.active::after {
  content: "";
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 3px;
  border-radius: 3px 3px 0 0;
  background: var(--fb-blue);
}

.fb-top-tabs span {
  display: none;
}

.fb-top-actions {
  justify-content: flex-end;
  gap: 8px;
}

.fb-circle-action,
.fb-avatar-button,
.fb-mobile-menu,
.fb-contact-heading button,
.fb-quick-chat header > div button {
  position: relative;
  flex: 0 0 auto;
  width: 40px;
  height: 40px;
  display: grid;
  place-items: center;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: var(--fb-control);
  color: var(--fb-text);
  cursor: pointer;
}

.fb-circle-action:hover,
.fb-circle-action.active,
.fb-contact-heading button:hover,
.fb-quick-chat header > div button:hover {
  background: #d8dadf;
}

.fb-avatar-button {
  background: transparent;
}

.fb-action-badge {
  position: absolute;
  top: -5px;
  right: -5px;
  min-width: 19px;
  height: 19px;
  padding: 0 5px;
  display: grid;
  place-items: center;
  border: 2px solid #fff;
  border-radius: 999px;
  background: var(--fb-red);
  color: #fff;
  font-size: 10px;
  font-style: normal;
  font-weight: 800;
}

.fb-mobile-menu {
  display: none;
}

.fb-popover-anchor {
  position: relative;
}

.fb-notification-popover,
.fb-profile-menu {
  position: absolute;
  top: 48px;
  right: 0;
  width: min(380px, calc(100vw - 24px));
  overflow: hidden;
  border-radius: 12px;
  background: #fff;
  box-shadow: var(--fb-shadow-large);
}

.fb-popover-title {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  padding: 16px 16px 10px;
}

.fb-popover-title h3 {
  margin: 0;
  font-size: 24px;
}

.fb-popover-title span {
  display: block;
  margin-top: 3px;
  color: var(--fb-muted);
  font-size: 12px;
}

.fb-popover-title button,
.fb-see-all {
  border: 0;
  background: transparent;
  color: var(--fb-blue);
  cursor: pointer;
  font-weight: 700;
}

.fb-notification-list {
  max-height: 430px;
  overflow: auto;
  padding: 0 8px;
}

.fb-notification-row {
  width: 100%;
  display: flex;
  align-items: flex-start;
  gap: 11px;
  padding: 10px 8px;
  border: 0;
  border-radius: 8px;
  background: transparent;
  text-align: left;
  cursor: pointer;
}

.fb-notification-row:hover {
  background: var(--fb-hover);
}

.fb-notification-row.unread {
  background: #edf5ff;
}

.fb-notification-copy {
  min-width: 0;
  flex: 1;
}

.fb-notification-copy b,
.fb-notification-copy p,
.fb-notification-copy time {
  display: block;
}

.fb-notification-copy b {
  font-size: 14px;
}

.fb-notification-copy p {
  margin: 3px 0;
  color: #1c1e21;
  font-size: 13px;
  line-height: 1.35;
}

.fb-notification-copy time {
  color: var(--fb-blue);
  font-size: 12px;
}

.fb-see-all {
  width: 100%;
  min-height: 42px;
  border-top: 1px solid var(--fb-line);
}

.fb-profile-menu {
  width: 340px;
  padding: 8px;
}

.fb-profile-menu > button {
  width: 100%;
  min-height: 48px;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px;
  border: 0;
  border-radius: 8px;
  background: transparent;
  text-align: left;
  cursor: pointer;
}

.fb-profile-menu > button:hover {
  background: var(--fb-hover);
}

.fb-profile-summary {
  padding: 10px !important;
  box-shadow: var(--fb-shadow);
}

.fb-profile-summary span,
.fb-profile-summary b,
.fb-profile-summary small {
  display: block;
}

.fb-profile-summary small {
  margin-top: 3px;
  color: var(--fb-muted);
}

.fb-menu-divider {
  height: 1px;
  margin: 8px 4px;
  background: var(--fb-line);
}

.fb-app-body {
  min-height: 100svh;
  padding-top: var(--top-nav-height);
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  justify-content: center;
  background: var(--fb-bg);
}

.fb-app-body.with-left {
  grid-template-columns: 280px minmax(0, 1fr);
}

.fb-app-body.with-left.with-right {
  grid-template-columns: 280px minmax(0, 720px) 300px;
}

.fb-left-rail,
.fb-right-rail {
  position: sticky;
  top: var(--top-nav-height);
  height: calc(100svh - var(--top-nav-height));
  overflow-y: auto;
  background: var(--fb-bg);
}

.fb-left-rail {
  padding: 16px 10px 18px 16px;
}

.fb-side-profile {
  gap: 10px;
  min-height: 48px;
  padding: 6px 8px;
  border-radius: 8px;
  color: var(--fb-text);
  font-weight: 700;
}

.fb-side-profile:hover,
.fb-side-nav a:hover,
.fb-contact-row:hover {
  background: #e4e6e9;
}

.fb-side-nav {
  display: grid;
  gap: 2px;
  margin-top: 6px;
  padding-bottom: 12px;
  border-bottom: 1px solid #ced0d4;
}

.fb-side-nav a {
  min-height: 48px;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 6px 8px;
  border-radius: 8px;
  color: var(--fb-text);
  font-size: 15px;
  font-weight: 700;
}

.fb-side-nav a.active {
  background: var(--fb-soft-blue);
  color: var(--fb-blue);
}

.fb-side-nav a > i {
  margin-left: auto;
  min-width: 20px;
  height: 20px;
  padding: 0 5px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  background: var(--fb-red);
  color: #fff;
  font-size: 10px;
  font-style: normal;
}

.fb-side-icon {
  width: 36px;
  height: 36px;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: #dbeafe;
  color: var(--fb-blue);
}

.fb-upcoming-card {
  margin-top: 14px;
  padding: 14px;
  border-radius: 12px;
  background: #fff;
  box-shadow: var(--fb-shadow);
}

.fb-upcoming-head {
  justify-content: space-between;
  gap: 8px;
  font-size: 13px;
  font-weight: 800;
}

.fb-upcoming-head > span {
  display: flex;
  align-items: center;
  gap: 7px;
}

.fb-upcoming-head button {
  border: 0;
  background: transparent;
  color: var(--fb-blue);
  cursor: pointer;
}

.fb-upcoming-card > p {
  margin: 12px 0;
  color: var(--fb-muted);
  font-size: 12px;
  line-height: 1.4;
}

.fb-upcoming-row {
  width: 100%;
  gap: 9px;
  padding: 9px 0;
  border: 0;
  border-bottom: 1px solid var(--fb-line);
  background: transparent;
  text-align: left;
  cursor: pointer;
}

.fb-upcoming-row > span:last-child {
  min-width: 0;
}

.fb-upcoming-row b,
.fb-upcoming-row small {
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.fb-upcoming-row b {
  font-size: 12px;
}

.fb-upcoming-row small {
  margin-top: 2px;
  color: var(--fb-muted);
  font-size: 10px;
}

.fb-meeting-mini-icon,
.fb-meeting-quick-icon,
.fb-right-promo-icon {
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: var(--fb-soft-blue);
  color: var(--fb-blue);
}

.fb-meeting-mini-icon {
  width: 32px;
  height: 32px;
}

.fb-create-meeting {
  width: 100%;
  min-height: 34px;
  margin-top: 10px;
  border: 0;
  border-radius: 7px;
  background: var(--fb-soft-blue);
  color: var(--fb-blue);
  font-weight: 700;
  cursor: pointer;
}

.fb-side-footer {
  padding: 16px 8px;
  color: var(--fb-muted);
  font-size: 11px;
}

.fb-main-route {
  min-width: 0;
  width: 100%;
}

.fb-route-view {
  min-width: 0;
  padding: 20px 18px 32px;
}

.fb-app-body.chat-route .fb-route-view {
  height: calc(100svh - var(--top-nav-height));
  padding: 12px;
}

.fb-app-body.chat-route .fb-main-route {
  max-width: none;
}

.fb-right-rail {
  padding: 18px 16px 20px 10px;
}

.fb-contact-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 2px 4px 10px;
}

.fb-contact-heading h3 {
  margin: 0;
  color: var(--fb-muted);
  font-size: 16px;
}

.fb-contact-heading > div {
  display: flex;
  gap: 4px;
}

.fb-contact-heading button {
  width: 32px;
  height: 32px;
  background: transparent;
}

.fb-contact-list {
  display: grid;
  gap: 2px;
}

.fb-contact-row {
  width: 100%;
  min-height: 44px;
  gap: 10px;
  padding: 4px 6px;
  border: 0;
  border-radius: 8px;
  background: transparent;
  text-align: left;
  font-weight: 700;
  cursor: pointer;
}

.fb-contact-avatar {
  position: relative;
  flex: 0 0 auto;
}

.fb-contact-avatar > i {
  position: absolute;
  right: -1px;
  bottom: 1px;
  width: 11px;
  height: 11px;
  border: 2px solid var(--fb-bg);
  border-radius: 50%;
  background: var(--fb-green);
}

.fb-right-promo {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-top: 18px;
  padding: 14px;
  border-top: 1px solid #ced0d4;
}

.fb-right-promo-icon {
  width: 38px;
  height: 38px;
}

.fb-right-promo b {
  font-size: 13px;
}

.fb-right-promo p {
  margin: 4px 0 8px;
  color: var(--fb-muted);
  font-size: 11px;
  line-height: 1.35;
}

.fb-right-promo button {
  padding: 6px 9px;
  border: 0;
  border-radius: 6px;
  background: var(--fb-soft-blue);
  color: var(--fb-blue);
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
}

.fb-empty-small {
  padding: 20px 10px;
  color: var(--fb-muted);
  text-align: center;
  font-size: 12px;
}

.fb-mobile-bottom-nav {
  display: none;
}

/* Messenger-like contact popup */
.fb-quick-chat {
  position: fixed;
  z-index: 1200;
  right: 24px;
  bottom: 0;
