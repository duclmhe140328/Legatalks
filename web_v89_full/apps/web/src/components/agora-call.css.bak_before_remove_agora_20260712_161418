/* One-to-one Agora call. Jitsi meeting styles are intentionally untouched. */
.agora-call-backdrop{position:fixed;z-index:12000;inset:0;display:grid;place-items:center;padding:18px;background:rgba(2,6,23,.72);backdrop-filter:blur(12px)}
.agora-call-shell{width:min(1180px,100%);height:min(760px,calc(100dvh - 36px));min-height:560px;display:grid;grid-template-rows:auto minmax(0,1fr) auto;overflow:hidden;border:1px solid rgba(148,163,184,.24);border-radius:28px;background:radial-gradient(circle at 18% 12%,rgba(24,119,242,.22),transparent 34%),radial-gradient(circle at 88% 16%,rgba(124,58,237,.18),transparent 30%),#07101f;color:#fff;box-shadow:0 36px 100px rgba(0,0,0,.5)}
.agora-call-head{min-height:76px;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:15px 20px;border-bottom:1px solid rgba(148,163,184,.14);background:rgba(7,16,31,.78)}
.agora-call-peer{min-width:0;display:flex;align-items:center;gap:12px}.agora-call-peer-copy{min-width:0}.agora-call-peer-copy strong{display:block;overflow:hidden;color:#fff;font-size:16px;text-overflow:ellipsis;white-space:nowrap}.agora-call-peer-copy span{display:block;margin-top:3px;color:#a9b6ca;font-size:12px}
.agora-call-provider{display:inline-flex;align-items:center;gap:7px;flex:0 0 auto;padding:8px 11px;border:1px solid rgba(96,165,250,.22);border-radius:999px;background:rgba(24,119,242,.12);color:#bfdbfe;font-size:12px;font-weight:800}
.agora-call-stage{position:relative;min-height:0;padding:18px}.agora-call-remote-grid{width:100%;height:100%;display:grid;gap:12px;grid-template-columns:repeat(auto-fit,minmax(min(100%,360px),1fr))}
.agora-call-remote-tile,.agora-call-empty{position:relative;min-height:0;overflow:hidden;border:1px solid rgba(148,163,184,.16);border-radius:22px;background:#020617}.agora-call-video-node{position:absolute;inset:0}.agora-call-video-node>div,.agora-call-video-node video{width:100%!important;height:100%!important;object-fit:contain!important}
.agora-call-empty{display:grid;place-items:center;padding:24px;text-align:center}.agora-call-empty-copy{display:grid;justify-items:center;gap:12px}.agora-call-empty-copy strong{font-size:22px}.agora-call-empty-copy span{max-width:520px;color:#94a3b8;line-height:1.55}
.agora-call-local{position:absolute;z-index:8;right:34px;bottom:34px;width:min(260px,25vw);aspect-ratio:16/10;overflow:hidden;border:2px solid rgba(255,255,255,.72);border-radius:18px;background:#111827;box-shadow:0 18px 42px rgba(0,0,0,.42)}.agora-call-local.is-hidden .agora-call-video-node{opacity:0}
.agora-call-local-label,.agora-call-remote-label{position:absolute;z-index:5;left:10px;bottom:10px;max-width:calc(100% - 20px);padding:6px 9px;overflow:hidden;border-radius:9px;background:rgba(2,6,23,.62);color:#fff;font-size:12px;font-weight:800;text-overflow:ellipsis;white-space:nowrap;backdrop-filter:blur(8px)}
.agora-call-local-off{position:absolute;z-index:4;inset:0;display:grid;place-items:center;background:linear-gradient(145deg,#172033,#0f172a);color:#cbd5e1;font-size:13px;font-weight:800}
.agora-call-controls{min-height:92px;display:flex;align-items:center;justify-content:center;gap:11px;padding:15px 20px;border-top:1px solid rgba(148,163,184,.14);background:rgba(7,16,31,.9)}
.agora-call-control{width:52px;height:52px;display:grid;place-items:center;border:0;border-radius:50%;background:#1e293b;color:#fff;cursor:pointer;transition:transform .16s ease,background .16s ease}.agora-call-control:hover{transform:translateY(-2px);background:#334155}.agora-call-control.is-off{background:#fff;color:#0f172a}.agora-call-control.is-danger{width:64px;height:64px;background:#ef4444}.agora-call-control.is-danger:hover{background:#dc2626}.agora-call-control:disabled{opacity:.48;cursor:not-allowed;transform:none}
.agora-call-error{position:absolute;z-index:12;left:50%;top:14px;width:min(620px,calc(100% - 28px));transform:translateX(-50%);padding:11px 13px;border:1px solid rgba(251,113,133,.35);border-radius:12px;background:rgba(136,19,55,.9);color:#fff;font-size:13px;font-weight:700;text-align:center}
@media(max-width:760px){.agora-call-backdrop{padding:0}.agora-call-shell{width:100%;height:100dvh;min-height:100dvh;border:0;border-radius:0}.agora-call-head{min-height:68px;padding:11px 13px}.agora-call-provider{display:none}.agora-call-stage{padding:0}.agora-call-remote-tile,.agora-call-empty{border:0;border-radius:0}.agora-call-local{right:12px;bottom:12px;width:116px;aspect-ratio:3/4;border-radius:14px}.agora-call-controls{min-height:82px;gap:9px;padding:10px 12px max(10px,env(safe-area-inset-bottom))}.agora-call-control{width:48px;height:48px}.agora-call-control.is-danger{width:58px;height:58px}}
