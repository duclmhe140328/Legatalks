import { useEffect, useMemo, useRef, useState } from 'react';
import {
  Camera,
  CameraOff,
  Expand,
  Mic,
  MicOff,
  PhoneOff,
  RefreshCcw,
  Volume2,
  VolumeX,
} from 'lucide-react';
import AgoraRTC from 'agora-rtc-sdk-ng';
import { api, errorMessage } from '../services/api';
import { useSocket } from '../context/SocketContext';
import Avatar from './Avatar';
import './agora-call.css';

/**
 * React StrictMode ở development có thể mount -> cleanup -> mount lại effect.
 * Bản CallModal cũ dùng mountedRef/leavingRef dùng chung giữa hai lượt effect,
 * khiến Agora client cũ chưa leave nhưng client mới đã join bằng cùng UID.
 *
 * Map này buộc phiên cũ phải dispose xong trước khi phiên mới cùng callSessionId
 * được phép join.
 */
const activeAgoraSessions = new Map();

function createClientInstanceId(callSessionId) {
  const randomPart = globalThis.crypto?.randomUUID?.()
    || `${Date.now()}-${Math.random().toString(36).slice(2)}`;

  return `web-${String(callSessionId || 'call')}-${randomPart}`;
}

function createAgoraSession(client) {
  const session = {
    client,
    microphoneTrack: null,
    cameraTrack: null,
    disposed: false,
    disposePromise: null,
  };

  session.dispose = () => {
    if (session.disposePromise) return session.disposePromise;

    session.disposed = true;
    session.disposePromise = (async () => {
      const microphoneTrack = session.microphoneTrack;
      const cameraTrack = session.cameraTrack;
      session.microphoneTrack = null;
      session.cameraTrack = null;

      try {
        microphoneTrack?.stop();
        microphoneTrack?.close();
      } catch {
        // Track đã đóng.
      }

      try {
        cameraTrack?.stop();
        cameraTrack?.close();
      } catch {
        // Track đã đóng.
      }

      try {
        client.removeAllListeners();
      } catch {
        // Client đã được dọn.
      }

      try {
        await client.leave();
      } catch {
        // Client chưa join hoặc đã leave.
      }
    })();

    return session.disposePromise;
  };

  return session;
}

function RemoteAgoraTile({ user, label, peer }) {
  const nodeRef = useRef(null);

  useEffect(() => {
    if (!nodeRef.current || !user?.videoTrack) return undefined;

    user.videoTrack.play(nodeRef.current, {
      fit: 'contain',
      mirror: false,
    });

    return () => {
      try {
        user.videoTrack?.stop();
      } catch {
        // Track đã dừng.
      }
    };
  }, [user, user?.videoTrack]);

  return (
    <div className="agora-call-remote-tile">
      <div ref={nodeRef} className="agora-call-video-node">
        {!user?.videoTrack && (
          <div className="agora-call-empty-copy">
            <Avatar user={peer} size={92} />
            <strong>{label}</strong>
            <span>Đã kết nối cuộc gọi thoại</span>
          </div>
        )}
      </div>
      <span className="agora-call-remote-label">{label}</span>
    </div>
  );
}

export default function CallModal({
  conversation,
  mode = 'video',
  callSessionId,
  direction = 'outgoing',
  externalStatus,
  onClose,
}) {
  const { socket } = useSocket();
  const activeSessionRef = useRef(null);
  const localNodeRef = useRef(null);
  const speakerOnRef = useRef(true);
  const clientInstanceIdRef = useRef('');

  if (!clientInstanceIdRef.current) {
    clientInstanceIdRef.current = createClientInstanceId(callSessionId);
  }

  const [remoteUsers, setRemoteUsers] = useState(() => new Map());
  const [joined, setJoined] = useState(false);
  const [joining, setJoining] = useState(true);
  const [ending, setEnding] = useState(false);
  const [micOn, setMicOn] = useState(true);
  const [cameraOn, setCameraOn] = useState(mode === 'video');
  const [speakerOn, setSpeakerOn] = useState(true);
  const [status, setStatus] = useState(
    direction === 'outgoing'
      ? 'Đang chuẩn bị cuộc gọi…'
      : 'Đang kết nối…',
  );
  const [failure, setFailure] = useState('');

  const isVideo = mode === 'video';
  const title = useMemo(
    () => conversation?.name
      || conversation?.members?.find((member) => member?.user?.displayName)
        ?.user?.displayName
      || 'Cuộc gọi Nexora',
    [conversation],
  );
  const peer = conversation?.members?.find((member) => member?.user)?.user
    || conversation;

  const setRemote = (user) => {
    setRemoteUsers((current) => {
      const next = new Map(current);
      next.set(String(user.uid), user);
      return next;
    });
  };

  const removeRemote = (uid) => {
    setRemoteUsers((current) => {
      const next = new Map(current);
      next.delete(String(uid));
      return next;
    });
  };

  const fetchCredentials = async (clientInstanceId) => {
    const encoded = encodeURIComponent(clientInstanceId);
    const response = await api.get(
      `/calls/${callSessionId}/agora-token?clientInstanceId=${encoded}`,
    );
    return response.data;
  };

  const disposeCurrentSession = async () => {
    const session = activeSessionRef.current;
    activeSessionRef.current = null;

    if (!session) return;
    await session.dispose();

    if (activeAgoraSessions.get(String(callSessionId)) === session) {
      activeAgoraSessions.delete(String(callSessionId));
    }
  };

  useEffect(() => {
    let cancelled = false;
    let session = null;
    const callKey = String(callSessionId);
    const clientInstanceId = clientInstanceIdRef.current;

    const alive = () => !cancelled && !session?.disposed;

    async function boot() {
      setJoining(true);
      setJoined(false);
      setRemoteUsers(new Map());
      setFailure('');

      try {
        // StrictMode hoặc rerender có thể để lại một client cùng callSessionId.
        // Phải leave xong hoàn toàn rồi mới tạo/join client kế tiếp.
        const previousSession = activeAgoraSessions.get(callKey);
        if (previousSession) {
          await previousSession.dispose();
          if (activeAgoraSessions.get(callKey) === previousSession) {
            activeAgoraSessions.delete(callKey);
          }
        }

        if (cancelled) return;

        const client = AgoraRTC.createClient({ mode: 'rtc', codec: 'vp8' });
        session = createAgoraSession(client);
        activeSessionRef.current = session;
        activeAgoraSessions.set(callKey, session);

        const onUserJoined = (user) => {
          if (!alive()) return;
          setRemote(user);
          setStatus('Đã kết nối người bên kia, đang nhận âm thanh/hình ảnh…');
        };

        const onUserPublished = async (user, mediaType) => {
          try {
            await client.subscribe(user, mediaType);
            if (!alive()) return;

            if (mediaType === 'audio') {
              user.audioTrack?.setVolume(speakerOnRef.current ? 100 : 0);
              user.audioTrack?.play();
            }

            setRemote(user);
            setStatus('Đang gọi');
          } catch (error) {
            if (alive()) setFailure(errorMessage(error));
          }
        };

        const onUserUnpublished = (user) => {
          if (!alive()) return;
          // Không xóa user chỉ vì tắt camera/micro; vẫn giữ trạng thái đã join.
          setRemote(user);
        };

        const onUserLeft = (user) => {
          if (!alive()) return;
          removeRemote(user.uid);
          setStatus('Người bên kia đã rời cuộc gọi');
        };

        const renewToken = async () => {
          try {
            const credentials = await fetchCredentials(clientInstanceId);
            if (!alive()) return;
            await client.renewToken(credentials.token);
          } catch (error) {
            if (alive()) {
              setFailure(
                `Không gia hạn được cuộc gọi: ${errorMessage(error)}`,
              );
            }
          }
        };

        client.on('user-joined', onUserJoined);
        client.on('user-published', onUserPublished);
        client.on('user-unpublished', onUserUnpublished);
        client.on('user-left', onUserLeft);
        client.on('token-privilege-will-expire', renewToken);
        client.on('token-privilege-did-expire', renewToken);
        client.on('connection-state-change', (currentState) => {
          if (!alive()) return;
          if (currentState === 'RECONNECTING') {
            setStatus('Mạng không ổn định, đang kết nối lại…');
          }
          if (currentState === 'DISCONNECTED') {
            setStatus('Đã ngắt kết nối');
          }
        });

        const credentials = await fetchCredentials(clientInstanceId);
        if (!alive()) return;

        await client.join(
          credentials.appId,
          credentials.channel,
          credentials.token,
          Number(credentials.uid),
        );

        if (!alive()) {
          await session.dispose();
          return;
        }

        const microphoneTrack = await AgoraRTC.createMicrophoneAudioTrack({
          encoderConfig: 'speech_standard',
          AEC: true,
          ANS: true,
          AGC: true,
        });
        session.microphoneTrack = microphoneTrack;

        if (!alive()) {
          await session.dispose();
          return;
        }

        let cameraTrack = null;
        if (isVideo) {
          cameraTrack = await AgoraRTC.createCameraVideoTrack({
            encoderConfig: '720p_2',
            facingMode: 'user',
          });
          session.cameraTrack = cameraTrack;

          if (localNodeRef.current && alive()) {
            cameraTrack.play(localNodeRef.current, {
              fit: 'cover',
              mirror: true,
            });
          }
        }

        if (!alive()) {
          await session.dispose();
          return;
        }

        await client.publish(
          cameraTrack ? [microphoneTrack, cameraTrack] : [microphoneTrack],
        );

        if (!alive()) {
          await session.dispose();
          return;
        }

        // Đồng bộ người đã có mặt trong channel, kể cả khi event user-joined
        // xảy ra rất sớm trước lúc React hoàn thành render.
        client.remoteUsers.forEach(setRemote);

        socket?.emit('call:join', {
          conversationId: conversation?._id,
          callSessionId,
          mode: isVideo ? 'video' : 'voice',
        });

        setJoined(true);
        setStatus(
          client.remoteUsers.length > 0
            ? 'Đang gọi'
            : direction === 'outgoing'
              ? 'Đang chờ người nhận tham gia…'
              : 'Đã vào cuộc gọi. Đang chờ âm thanh/hình ảnh…',
        );
      } catch (error) {
        if (!cancelled) {
          const message = errorMessage(error);
          setFailure(
            message.includes('UID_CONFLICT')
              ? 'Agora phát hiện phiên gọi trùng UID. Phiên cũ đang được dọn, hãy đóng cuộc gọi và gọi lại một lần.'
              : message,
          );
          setStatus('Không thể mở cuộc gọi Agora');
        }

        if (session) await session.dispose();
      } finally {
        if (!cancelled) setJoining(false);
      }
    }

    void boot();

    return () => {
      cancelled = true;
      const currentSession = session;

      if (activeSessionRef.current === currentSession) {
        activeSessionRef.current = null;
      }

      void (async () => {
        if (currentSession) await currentSession.dispose();
        if (activeAgoraSessions.get(callKey) === currentSession) {
          activeAgoraSessions.delete(callKey);
        }
      })();
    };
  }, [callSessionId, conversation?._id, direction, isVideo, socket]);

  useEffect(() => {
    if (externalStatus && remoteUsers.size === 0) {
      setStatus(externalStatus);
    }
  }, [externalStatus, remoteUsers.size]);

  const currentSession = () => activeSessionRef.current;

  const toggleMicrophone = async () => {
    const next = !micOn;
    try {
      await currentSession()?.microphoneTrack?.setEnabled(next);
      setMicOn(next);
    } catch (error) {
      setFailure(errorMessage(error));
    }
  };

  const toggleCamera = async () => {
    if (!isVideo) return;
    const next = !cameraOn;
    try {
      await currentSession()?.cameraTrack?.setEnabled(next);
      setCameraOn(next);
    } catch (error) {
      setFailure(errorMessage(error));
    }
  };

  const switchCamera = async () => {
    const cameraTrack = currentSession()?.cameraTrack;
    if (!isVideo || !cameraTrack) return;

    try {
      const cameras = await AgoraRTC.getCameras();
      if (cameras.length < 2) {
        setFailure('Thiết bị chỉ có một camera.');
        return;
      }

      const currentLabel = cameraTrack.getTrackLabel();
      const currentIndex = cameras.findIndex(
        (camera) => camera.label === currentLabel,
      );
      const nextCamera = cameras[
        (currentIndex + 1 + cameras.length) % cameras.length
      ];
      await cameraTrack.setDevice(nextCamera.deviceId);
    } catch (error) {
      setFailure(errorMessage(error));
    }
  };

  const toggleSpeaker = () => {
    const next = !speakerOn;
    speakerOnRef.current = next;
    setSpeakerOn(next);

    remoteUsers.forEach((user) => {
      user.audioTrack?.setVolume(next ? 100 : 0);
      if (next) user.audioTrack?.play();
    });
  };

  const enterFullscreen = async () => {
    try {
      if (document.fullscreenElement) {
        await document.exitFullscreen();
      } else {
        await document
          .querySelector('.agora-call-shell')
          ?.requestFullscreen?.();
      }
    } catch (error) {
      setFailure(errorMessage(error));
    }
  };

  const endCall = async () => {
    if (ending) return;
    setEnding(true);

    try {
      socket?.emit('call:leave', { callSessionId });
      await api.post(`/calls/${callSessionId}/end`);
    } catch {
      // Đầu bên kia có thể đã kết thúc trước.
    } finally {
      await disposeCurrentSession();
      onClose?.();
    }
  };

  const remoteList = [...remoteUsers.values()];

  return (
    <div className="agora-call-backdrop">
      <section className="agora-call-shell">
        <header className="agora-call-head">
          <div className="agora-call-peer">
            <Avatar user={peer} size={44} />
            <div className="agora-call-peer-copy">
              <strong>{title}</strong>
              <span>{joining ? 'Đang mở camera/micro…' : status}</span>
            </div>
          </div>
          <div className="agora-call-provider">
            Agora RTC · {isVideo ? 'Video' : 'Thoại'}
          </div>
        </header>

        <main className="agora-call-stage">
          {failure && <div className="agora-call-error">{failure}</div>}

          <div className="agora-call-remote-grid">
            {remoteList.length === 0 ? (
              <div className="agora-call-empty">
                <div className="agora-call-empty-copy">
                  <Avatar user={peer} size={92} />
                  <strong>{title}</strong>
                  <span>
                    {joining
                      ? 'Đang tham gia kênh Agora…'
                      : 'Đã vào cuộc gọi. Đang chờ người bên kia tham gia.'}
                  </span>
                </div>
              </div>
            ) : (
              remoteList.map((user) => (
                <RemoteAgoraTile
                  key={String(user.uid)}
                  user={user}
                  label={title}
                  peer={peer}
                />
              ))
            )}
          </div>

          {isVideo && (
            <div
              className={`agora-call-local ${cameraOn ? '' : 'is-hidden'}`}
            >
              <div ref={localNodeRef} className="agora-call-video-node" />
              {!cameraOn && (
                <div className="agora-call-local-off">Camera đang tắt</div>
              )}
              <span className="agora-call-local-label">Bạn</span>
            </div>
          )}
        </main>

        <footer className="agora-call-controls">
          <button
            className={`agora-call-control ${micOn ? '' : 'is-off'}`}
            onClick={toggleMicrophone}
            disabled={!joined}
            title={micOn ? 'Tắt micro' : 'Bật micro'}
          >
            {micOn ? <Mic size={22} /> : <MicOff size={22} />}
          </button>

          {isVideo && (
            <>
              <button
                className={`agora-call-control ${cameraOn ? '' : 'is-off'}`}
                onClick={toggleCamera}
                disabled={!joined}
                title={cameraOn ? 'Tắt camera' : 'Bật camera'}
              >
                {cameraOn
                  ? <Camera size={22} />
                  : <CameraOff size={22} />}
              </button>
              <button
                className="agora-call-control"
                onClick={switchCamera}
                disabled={!joined}
                title="Đổi camera"
              >
                <RefreshCcw size={21} />
              </button>
            </>
          )}

          <button
            className={`agora-call-control ${speakerOn ? '' : 'is-off'}`}
            onClick={toggleSpeaker}
            disabled={!joined}
            title={speakerOn ? 'Tắt tiếng loa' : 'Bật tiếng loa'}
          >
            {speakerOn ? <Volume2 size={22} /> : <VolumeX size={22} />}
          </button>

          <button
            className="agora-call-control"
            onClick={enterFullscreen}
            title="Toàn màn hình"
          >
            <Expand size={21} />
          </button>

          <button
            className="agora-call-control is-danger"
            onClick={endCall}
            disabled={ending}
            title="Kết thúc cuộc gọi"
          >
            <PhoneOff size={25} />
          </button>
        </footer>
      </section>
    </div>
  );
}
