  );
}

export default function AuthEmailPage({ initialMode = 'login' }) {
  const navigate = useNavigate();
  const auth = useAuth();
  const [mode, setMode] = useState(initialMode || 'login');
  const [loading, setLoading] = useState(false);
  const [sendingOtp, setSendingOtp] = useState(false);
  const [message, setMessage] = useState('');
  const [form, setForm] = useState({
    phone: '84901111111',
    email: '',
    displayName: '',
    password: '12345678',
    confirmPassword: '',
    otp: '',
    account: '',
    newPassword: '',
  });

  useEffect(() => {
    setMode(initialMode || 'login');
    setMessage('');
  }, [initialMode]);

  function setField(key, value) {
    setForm((prev) => ({ ...prev, [key]: value }));
  }

  function setModeAndUrl(nextMode) {
    setMessage('');
    setMode(nextMode);

    if (nextMode === 'register') navigate('/register', { replace: true });
    else if (nextMode === 'forgot') navigate('/forgot-password', { replace: true });
    else navigate('/login', { replace: true });
  }

  function accountPayload() {
    const raw = String(form.account || '').trim();
    if (isEmail(raw)) return { email: raw.toLowerCase() };
    return { phone: raw };
  }

  async function saveSession(data) {
    if (data?.accessToken) localStorage.setItem('accessToken', data.accessToken);
    if (data?.refreshToken) localStorage.setItem('refreshToken', data.refreshToken);
    if (data?.user) localStorage.setItem('user', JSON.stringify(data.user));

    if (typeof auth?.reload === 'function') await auth.reload();
    if (typeof auth?.refresh === 'function') await auth.refresh();
    if (typeof auth?.setUser === 'function' && data?.user) auth.setUser(data.user);
  }

  async function login() {
    setLoading(true);
    setMessage('');

    try {
      const { data } = await api.post('/auth/login/password', {
        phone: form.phone.trim(),
        password: form.password,
        device: { platform: 'web', name: 'Web Browser' },
      });

      await saveSession(data);
      navigate('/chats', { replace: true });
      window.location.reload();
    } catch (error) {
      setMessage(cleanError(error));
    } finally {
      setLoading(false);
    }
  }

  async function requestRegisterOtp() {
    const email = form.email.trim().toLowerCase();

    if (!form.phone.trim() || !email) {
      setMessage('Nhập số điện thoại và Gmail trước.');
      return;
    }

    if (!isEmail(email)) {
      setMessage('Gmail không hợp lệ.');
      return;
    }

    setSendingOtp(true);
    setMessage('');

    try {
      const { data } = await api.post('/auth/request-otp', {
        phone: form.phone.trim(),
        email,
        purpose: 'register',
        channel: 'email',
      });

      if (data.devCode) setField('otp', data.devCode);
      setMessage(data.message || 'Đã gửi OTP về Gmail.');
    } catch (error) {
      setMessage(cleanError(error));
    } finally {
      setSendingOtp(false);
    }
  }

  async function register() {
    const email = form.email.trim().toLowerCase();

    if (!form.displayName.trim() || !form.phone.trim() || !email || !form.password || !form.otp.trim()) {
      setMessage('Nhập đủ tên, số điện thoại, Gmail, mật khẩu và OTP.');
      return;
    }

    if (form.confirmPassword && form.confirmPassword !== form.password) {
      setMessage('Mật khẩu nhập lại không khớp.');
      return;
    }

    setLoading(true);
    setMessage('');

    try {
      const { data } = await api.post('/auth/register', {
        phone: form.phone.trim(),
        email,
        displayName: form.displayName.trim(),
        password: form.password,
        otp: form.otp.trim(),
        accountType: 'personal',
        device: { platform: 'web', name: 'Web Browser' },
      });

      await saveSession(data);
      navigate('/chats', { replace: true });
      window.location.reload();
    } catch (error) {
      setMessage(cleanError(error));
    } finally {
      setLoading(false);
    }
  }

  async function requestResetOtp() {
    if (!form.account.trim()) {
      setMessage('Nhập Gmail hoặc số điện thoại tài khoản.');
      return;
    }

    setSendingOtp(true);
    setMessage('');

    try {
      const { data } = await api.post('/auth/forgot-password', accountPayload());

      if (data.devCode) setField('otp', data.devCode);
      setMessage(data.message || 'Đã gửi OTP đặt lại mật khẩu.');
    } catch (error) {
      setMessage(cleanError(error));
    } finally {
      setSendingOtp(false);
    }
  }

  async function resetPassword() {
    if (!form.account.trim() || !form.otp.trim() || !form.newPassword) {
      setMessage('Nhập Gmail/số điện thoại, OTP và mật khẩu mới.');
      return;
    }

    if (form.confirmPassword && form.confirmPassword !== form.newPassword) {
      setMessage('Mật khẩu nhập lại không khớp.');
      return;
    }

    setLoading(true);
    setMessage('');

    try {
      await api.post('/auth/reset-password', {
        ...accountPayload(),
        otp: form.otp.trim(),
        newPassword: form.newPassword,
      });

      setMessage('Đã đổi mật khẩu. Hãy đăng nhập lại.');
      setModeAndUrl('login');
    } catch (error) {
      setMessage(cleanError(error));
    } finally {
      setLoading(false);
    }
  }

  const title = mode === 'register' ? 'Tạo tài khoản' : mode === 'forgot' ? 'Khôi phục mật khẩu' : 'Chào mừng trở lại';
  const subtitle = mode === 'register'
    ? 'Nhập Gmail để nhận OTP bảo mật khi đăng ký tài khoản mới.'
    : mode === 'forgot'
      ? 'Nhận OTP qua Gmail rồi đặt lại mật khẩu trong vài giây.'
      : 'Đăng nhập Nexora Connect để tiếp tục chat, gọi, họp và quản lý công việc.';

  return (
    <div className="nexora-auth">
      <style>{css}</style>

      <section className="nexora-auth-left">
        <div className="nexora-auth-glow one" />
        <div className="nexora-auth-glow two" />

        <div className="nexora-auth-brand">
          <div className="nexora-auth-logo">N</div>
          <div>
            <h1>Nexora Connect</h1>
            <p>Social workspace platform</p>
          </div>
        </div>

        <div className="nexora-auth-hero">
          <div className="nexora-auth-kicker">● Live · Chat · Meeting · Mini Apps</div>
          <h2>Kết nối đội nhóm <span>trong một nền tảng.</span></h2>
          <p>
            Giao diện đồng bộ với dự án: xanh Nexora, glass card, bo góc lớn, bóng mềm và luồng xác thực bằng Gmail OTP.
          </p>

          <div className="nexora-auth-features">
            <div className="nexora-auth-feature"><b>Gmail OTP</b><span>Nhận mã khi đăng ký và quên mật khẩu.</span></div>
            <div className="nexora-auth-feature"><b>Realtime</b><span>Chat, thông báo, gọi và họp online.</span></div>
            <div className="nexora-auth-feature"><b>Bảo mật</b><span>Đổi mật khẩu ngay trong dashboard.</span></div>
          </div>
        </div>
      </section>

      <section className="nexora-auth-right">
        <div className="nexora-auth-card">
          <h2 className="nexora-auth-title">{title}</h2>
          <p className="nexora-auth-subtitle">{subtitle}</p>

          {mode !== 'forgot' ? (
            <div className="nexora-auth-tabs">
              <button type="button" className={`nexora-auth-tab ${mode === 'login' ? 'active' : ''}`} onClick={() => setModeAndUrl('login')}>Đăng nhập</button>
              <button type="button" className={`nexora-auth-tab ${mode === 'register' ? 'active' : ''}`} onClick={() => setModeAndUrl('register')}>Đăng ký</button>
            </div>
          ) : <div style={{ height: 18 }} />}

          <div className="nexora-auth-form">
            {mode === 'login' ? (
              <>
                <Field icon="☎" value={form.phone} onChange={(e) => setField('phone', e.target.value)} placeholder="Số điện thoại" />
                <Field icon="🔒" type="password" value={form.password} onChange={(e) => setField('password', e.target.value)} placeholder="Mật khẩu" />
                <button type="button" className="nexora-auth-btn" disabled={loading} onClick={login}>{loading ? 'Đang xử lý...' : 'Đăng nhập'}</button>
                <button type="button" className="nexora-auth-link-btn" onClick={() => setModeAndUrl('forgot')}>Quên mật khẩu?</button>
                <div className="nexora-auth-foot">Chưa có tài khoản? <Link to="/register">Đăng ký ngay</Link></div>
              </>
            ) : null}

            {mode === 'register' ? (
              <>
                <Field icon="👤" value={form.displayName} onChange={(e) => setField('displayName', e.target.value)} placeholder="Tên hiển thị" />
                <Field icon="☎" value={form.phone} onChange={(e) => setField('phone', e.target.value)} placeholder="Số điện thoại" />
                <Field icon="✉" value={form.email} onChange={(e) => setField('email', e.target.value)} placeholder="Gmail nhận OTP" />
                <Field icon="🔒" type="password" value={form.password} onChange={(e) => setField('password', e.target.value)} placeholder="Mật khẩu" />
                <Field icon="✓" type="password" value={form.confirmPassword} onChange={(e) => setField('confirmPassword', e.target.value)} placeholder="Nhập lại mật khẩu" />
                <div className="nexora-auth-split">
                  <Field icon="✦" value={form.otp} onChange={(e) => setField('otp', e.target.value)} placeholder="OTP Gmail" />
                  <button type="button" className="nexora-auth-btn secondary" disabled={sendingOtp} onClick={requestRegisterOtp}>{sendingOtp ? 'Gửi...' : 'Gửi OTP'}</button>
                </div>
                <button type="button" className="nexora-auth-btn" disabled={loading} onClick={register}>{loading ? 'Đang tạo...' : 'Tạo tài khoản'}</button>
                <div className="nexora-auth-foot">Đã có tài khoản? <Link to="/login">Đăng nhập</Link></div>
              </>
            ) : null}

            {mode === 'forgot' ? (
              <>
                <Field icon="@" value={form.account} onChange={(e) => setField('account', e.target.value)} placeholder="Gmail hoặc số điện thoại" />
                <div className="nexora-auth-split">
                  <Field icon="✦" value={form.otp} onChange={(e) => setField('otp', e.target.value)} placeholder="OTP" />
                  <button type="button" className="nexora-auth-btn secondary" disabled={sendingOtp} onClick={requestResetOtp}>{sendingOtp ? 'Gửi...' : 'Gửi OTP'}</button>
                </div>
                <Field icon="🔒" type="password" value={form.newPassword} onChange={(e) => setField('newPassword', e.target.value)} placeholder="Mật khẩu mới" />
                <Field icon="✓" type="password" value={form.confirmPassword} onChange={(e) => setField('confirmPassword', e.target.value)} placeholder="Nhập lại mật khẩu mới" />
                <button type="button" className="nexora-auth-btn" disabled={loading} onClick={resetPassword}>{loading ? 'Đang xử lý...' : 'Đặt lại mật khẩu'}</button>
                <button type="button" className="nexora-auth-link-btn" onClick={() => setModeAndUrl('login')}>Quay lại đăng nhập</button>
              </>
            ) : null}
          </div>

          {message ? <div className="nexora-auth-message">{message}</div> : null}
        </div>
      </section>
    </div>
  );
}
