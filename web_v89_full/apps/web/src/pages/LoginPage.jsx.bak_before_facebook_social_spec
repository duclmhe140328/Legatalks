import { useState } from 'react';
import { Link, Navigate } from 'react-router-dom';
import { Fingerprint, KeyRound, MessageCircleMore, Phone } from 'lucide-react';
import { startAuthentication } from '@simplewebauthn/browser';
import { api, errorMessage } from '../services/api';
import { useAuth } from '../context/AuthContext';

const device = () => ({ deviceId: localStorage.getItem('deviceId') || crypto.randomUUID(), deviceName: navigator.platform || 'Web browser' });

export default function LoginPage() {
  const { user, saveAuth } = useAuth();
  const [mode, setMode] = useState('password');
  const [phone, setPhone] = useState('0901111111');
  const [password, setPassword] = useState('12345678');
  const [otp, setOtp] = useState('');
  const [devCode, setDevCode] = useState('');
  const [status, setStatus] = useState('');
  const [loading, setLoading] = useState(false);

  if (user) return <Navigate to="/" replace />;

  const rememberDevice = (d) => localStorage.setItem('deviceId', d.deviceId);
  const submit = async (event) => {
    event.preventDefault(); setLoading(true); setStatus('');
    try {
      const d = device(); rememberDevice(d);
      const endpoint = mode === 'password' ? '/auth/login/password' : '/auth/login/otp';
      const payload = mode === 'password' ? { phone, password, device: d } : { phone, otp, device: d };
      const { data } = await api.post(endpoint, payload);
      saveAuth(data);
    } catch (error) { setStatus(errorMessage(error)); }
    finally { setLoading(false); }
  };

  const sendOtp = async () => {
    try {
      const { data } = await api.post('/auth/request-otp', { phone, purpose: 'login' });
      setDevCode(data.devCode || ''); setStatus(data.devCode ? `OTP local: ${data.devCode}` : data.message); setMode('otp');
    } catch (error) { setStatus(errorMessage(error)); }
  };

  const passkeyLogin = async () => {
    setLoading(true); setStatus('');
    try {
      const options = (await api.post('/auth/passkeys/login/options', { phone })).data;
      const response = await startAuthentication({ optionsJSON: options });
      const d = device(); rememberDevice(d);
      const { data } = await api.post('/auth/passkeys/login/verify', { phone, response, device: d });
      saveAuth(data);
    } catch (error) { setStatus(errorMessage(error)); }
    finally { setLoading(false); }
  };

  return (
    <div className="auth-page">
      <section className="auth-visual">
        <div className="visual-orb one" /><div className="visual-orb two" />
        <div className="auth-copy"><div className="brand-mark">N</div><h1>Kết nối không giới hạn.</h1><p>Nhắn tin realtime, gọi video, timeline, Official Account và Mini App trong cùng một hệ sinh thái.</p>
          <div className="feature-pills"><span><MessageCircleMore /> Realtime</span><span><Fingerprint /> Sinh trắc học</span><span><Phone /> Đa thiết bị</span></div>
        </div>
      </section>
      <section className="auth-panel">
        <form className="auth-card" onSubmit={submit}>
          <div className="mobile-brand"><span className="brand-mark small">N</span> Nexora Connect</div>
          <h2>Chào mừng trở lại</h2><p className="muted">Đăng nhập vào không gian kết nối của bạn.</p>
          <label>Số điện thoại<input value={phone} onChange={(e) => setPhone(e.target.value)} placeholder="0901 111 111" /></label>
          <div className="auth-tabs"><button type="button" className={mode === 'password' ? 'active' : ''} onClick={() => setMode('password')}>Mật khẩu</button><button type="button" className={mode === 'otp' ? 'active' : ''} onClick={() => setMode('otp')}>SMS OTP</button></div>
          {mode === 'password' ? (
            <label>Mật khẩu<input type="password" value={password} onChange={(e) => setPassword(e.target.value)} /></label>
          ) : (
            <label>Mã OTP<div className="inline-field"><input value={otp} onChange={(e) => setOtp(e.target.value)} placeholder={devCode || '6 chữ số'} /><button type="button" onClick={sendOtp}>Gửi mã</button></div></label>
          )}
          {status && <div className="form-status">{status}</div>}
          <button className="primary-btn" disabled={loading}><KeyRound size={18} /> {loading ? 'Đang xử lý…' : 'Đăng nhập'}</button>
          <button className="secondary-btn" type="button" onClick={passkeyLogin} disabled={loading}><Fingerprint size={20} /> FaceID / Fingerprint</button>
          <p className="auth-foot">Chưa có tài khoản? <Link to="/register">Đăng ký ngay</Link></p>
          <div className="demo-note">Demo: 0901111111 / 12345678</div>
        </form>
      </section>
    </div>
  );
}
