import express from 'express';
import bcrypt from 'bcryptjs';
import crypto from 'node:crypto';
import rateLimit from 'express-rate-limit';
import {
  generateAuthenticationOptions,
  generateRegistrationOptions,
  verifyAuthenticationResponse,
  verifyRegistrationResponse
} from '@simplewebauthn/server';
import User from '../models/User.js';
import Otp from '../models/Otp.js';
import { env } from '../config/env.js';
import { requireAuth } from '../middleware/auth.js';
import { asyncHandler } from '../utils/asyncHandler.js';
import { normalizePhone } from '../utils/phone.js';
import { hashToken, verifyRefreshToken, createAccessToken, createRefreshToken } from '../utils/tokens.js';
import { createSession } from '../services/session.js';
import { sendOtpSms } from '../services/sms.js';
import { sendOtpEmail } from '../services/email.js';

const router = express.Router();
const otpLimiter = rateLimit({ windowMs: 60_000, limit: 5, standardHeaders: true, legacyHeaders: false });


function normalizeEmail(value) {
  return String(value || '').trim().toLowerCase();
}

function isEmail(value) {
  return normalizeEmail(value).includes('@');
}

async function sendOtpByChannel({ phone, email, code, purpose }) {
  const normalizedEmail = normalizeEmail(email);

  if (normalizedEmail) {
    await sendOtpEmail(normalizedEmail, code, purpose);
    return 'email';
  }

  await sendOtpSms(phone, code);
  return 'sms';
}

async function findUserByAccount({ phone, email }) {
  const conditions = [];

  if (phone) conditions.push({ phone: String(phone).trim() });
  if (email) conditions.push({ email: normalizeEmail(email) });

  if (!conditions.length) return null;

  return User.findOne({ $or: conditions });
}
const hashOtp = (phone, code) => crypto.createHash('sha256').update(`${phone}:${code}:${env.jwtAccessSecret}`).digest('hex');

async function verifyOtp(phone, purpose, code) {
  const record = await Otp.findOne({ phone, purpose, consumedAt: null, expiresAt: { $gt: new Date() } }).sort({ createdAt: -1 });
  if (!record) throw Object.assign(new Error('OTP không tồn tại hoặc đã hết hạn.'), { status: 400 });
  if (record.attempts >= 5) throw Object.assign(new Error('OTP đã bị khóa do nhập sai quá nhiều lần.'), { status: 429 });
  if (record.codeHash !== hashOtp(phone, code)) {
    record.attempts += 1;
    await record.save();
    throw Object.assign(new Error('Mã OTP không đúng.'), { status: 400 });
  }
  record.consumedAt = new Date();
  await record.save();
}


router.post('/request-otp', otpLimiter, asyncHandler(async (req, res) => {
  const phone = String(req.body.phone || '').trim();
  const email = normalizeEmail(req.body.email);
  const purpose = req.body.purpose || 'login';

  if (!['register', 'login', 'reset'].includes(purpose)) {
    return res.status(400).json({ message: 'Muc dich OTP khong hop le.' });
  }

  if (!phone && !email) {
    return res.status(400).json({ message: 'Nhap so dien thoai hoac Gmail.' });
  }

  const existing = await findUserByAccount({ phone, email });

  if (purpose === 'register') {
    if (!phone) return res.status(400).json({ message: 'Dang ky can so dien thoai.' });
    if (!email) return res.status(400).json({ message: 'Dang ky can Gmail de nhan OTP.' });

    const byPhone = await User.findOne({ phone });
    if (byPhone) return res.status(409).json({ message: 'So dien thoai da dang ky.' });

    const byEmail = await User.findOne({ email });
    if (byEmail) return res.status(409).json({ message: 'Gmail da dang ky.' });
  }

  if (purpose === 'login' && !existing) {
    return res.status(404).json({ message: 'Tai khoan chua ton tai.' });
  }

  if (purpose === 'reset' && !existing) {
    return res.status(404).json({ message: 'Tai khoan chua ton tai.' });
  }

  const otpPhone = purpose === 'register' ? phone : (existing?.phone || phone);
  const targetEmail = purpose === 'register' ? email : (existing?.email || email);

  const code = createOtpCode();

  await Otp.deleteMany({ phone: otpPhone, purpose, consumedAt: null });
  await Otp.create({
    phone: otpPhone,
    purpose,
    codeHash: hashOtp(otpPhone, code),
    expiresAt: new Date(Date.now() + env.otpTtlMinutes * 60_000),
  });

  const channel = await sendOtpByChannel({
    phone: otpPhone,
    email: targetEmail,
    code,
    purpose,
  });

  res.json({
    message: channel === 'email' ? 'Da gui OTP ve Gmail.' : 'Da gui OTP.',
    channel,
    expiresInSeconds: env.otpTtlMinutes * 60,
    ...(shouldExposeDevOtp() ? { devCode: code } : {}),
  });
}));


router.post('/register', asyncHandler(async (req, res) => {
  const phone = String(req.body.phone || '').trim();
  const email = normalizeEmail(req.body.email);
  const { otp, displayName, password, accountType = 'personal', device = {} } = req.body;

  if (!phone || !email || !otp || !displayName || !password) {
    return res.status(400).json({ message: 'Nhap du so dien thoai, Gmail, OTP, ten va mat khau.' });
  }

  await verifyOtp(phone, 'register', otp);

  const byPhone = await User.findOne({ phone });
  if (byPhone) return res.status(409).json({ message: 'So dien thoai da dang ky.' });

  const byEmail = await User.findOne({ email });
  if (byEmail) return res.status(409).json({ message: 'Gmail da dang ky.' });

  const passwordHash = password ? await bcrypt.hash(password, 12) : undefined;
  const user = await User.create({
    phone,
    email,
    displayName: displayName.trim(),
    passwordHash,
    accountType,
  });

  const result = await createSession(user, req, device);
  res.status(201).json(result);
}));

router.post('/login/password', asyncHandler(async (req, res) => {
  const phone = normalizePhone(req.body.phone);
  const user = await User.findOne({ phone }).select('+passwordHash');
  if (!user?.passwordHash || !(await bcrypt.compare(req.body.password || '', user.passwordHash))) {
    return res.status(401).json({ message: 'Số điện thoại hoặc mật khẩu không đúng.' });
  }
  const result = await createSession(user, req, req.body.device || {});
  res.json(result);
}));

router.post('/login/otp', asyncHandler(async (req, res) => {
  const phone = normalizePhone(req.body.phone);
  await verifyOtp(phone, 'login', req.body.otp);
  const user = await User.findOne({ phone });
  if (!user) return res.status(404).json({ message: 'Tài khoản không tồn tại.' });
  const result = await createSession(user, req, req.body.device || {});
  res.json(result);
}));

router.post('/refresh', asyncHandler(async (req, res) => {
  const token = req.body.refreshToken;
  if (!token) return res.status(400).json({ message: 'Thiếu refresh token.' });
  const payload = verifyRefreshToken(token);
  const user = await User.findById(payload.sub);
  const session = user?.sessions.id(payload.sid);
  if (!user || !session || session.revokedAt || session.refreshTokenHash !== hashToken(token)) {
    return res.status(401).json({ message: 'Refresh token không hợp lệ.' });
  }
  const nextRefresh = createRefreshToken(user, session._id);
  session.refreshTokenHash = hashToken(nextRefresh);
  session.lastSeenAt = new Date();
  await user.save();
  res.json({ accessToken: createAccessToken(user, session._id), refreshToken: nextRefresh });
}));


router.post('/forgot-password', otpLimiter, asyncHandler(async (req, res) => {
  const phone = String(req.body.phone || '').trim();
  const email = normalizeEmail(req.body.email);

  const user = await findUserByAccount({ phone, email });

  if (!user) {
    return res.status(404).json({ message: 'Tai khoan chua ton tai.' });
  }

  const code = createOtpCode();

  await Otp.deleteMany({ phone: user.phone, purpose: 'reset', consumedAt: null });
  await Otp.create({
    phone: user.phone,
    purpose: 'reset',
    codeHash: hashOtp(user.phone, code),
    expiresAt: new Date(Date.now() + env.otpTtlMinutes * 60_000),
  });

  const channel = await sendOtpByChannel({
    phone: user.phone,
    email: user.email || email,
    code,
    purpose: 'reset',
  });

  res.json({
    message: channel === 'email' ? 'Da gui OTP dat lai mat khau ve Gmail.' : 'Da gui OTP dat lai mat khau.',
    channel,
    expiresInSeconds: env.otpTtlMinutes * 60,
    ...(shouldExposeDevOtp() ? { devCode: code } : {}),
  });
}));

router.post('/reset-password', asyncHandler(async (req, res) => {
  const phone = String(req.body.phone || '').trim();
  const email = normalizeEmail(req.body.email);
  const otp = String(req.body.otp || '').trim();
  const password = String(req.body.newPassword || req.body.password || '');

  if (!otp || !password) {
    return res.status(400).json({ message: 'Nhap OTP va mat khau moi.' });
  }

  if (password.length < 6) {
    return res.status(400).json({ message: 'Mat khau moi phai tu 6 ky tu.' });
  }

  const user = await findUserByAccount({ phone, email });

  if (!user) {
    return res.status(404).json({ message: 'Tai khoan chua ton tai.' });
  }

  await verifyOtp(user.phone, 'reset', otp);

  user.passwordHash = await bcrypt.hash(password, 12);
  await user.save();

  res.json({ message: 'Da dat lai mat khau. Hay dang nhap lai.' });
}));

router.post('/change-password', requireAuth, asyncHandler(async (req, res) => {
  const currentPassword = String(req.body.currentPassword || req.body.oldPassword || '');
  const newPassword = String(req.body.newPassword || req.body.password || '');

  if (!currentPassword || !newPassword) {
    return res.status(400).json({ message: 'Nhap mat khau hien tai va mat khau moi.' });
  }

  if (newPassword.length < 6) {
    return res.status(400).json({ message: 'Mat khau moi phai tu 6 ky tu.' });
  }

  const user = await User.findById(req.user._id).select('+passwordHash');

  if (!user?.passwordHash || !(await bcrypt.compare(currentPassword, user.passwordHash))) {
    return res.status(400).json({ message: 'Mat khau hien tai khong dung.' });
  }

  user.passwordHash = await bcrypt.hash(newPassword, 12);
  await user.save();

  res.json({ message: 'Da doi mat khau.' });
}));

router.post('/logout', requireAuth, asyncHandler(async (req, res) => {
  const session = req.user.sessions.id(req.sessionId);
  if (session) session.revokedAt = new Date();
  await req.user.save();
  res.json({ message: 'Đã đăng xuất.' });
}));

router.get('/sessions', requireAuth, (req, res) => {
  res.json(req.user.sessions.map((session) => ({
    id: session._id,
    deviceId: session.deviceId,
    deviceName: session.deviceName,
    userAgent: session.userAgent,
    ip: session.ip,
    createdAt: session.createdAt,
    lastSeenAt: session.lastSeenAt,
    revokedAt: session.revokedAt,
    current: String(session._id) === String(req.sessionId)
  })));
});

router.delete('/sessions/:id', requireAuth, asyncHandler(async (req, res) => {
  const session = req.user.sessions.id(req.params.id);
  if (!session) return res.status(404).json({ message: 'Không tìm thấy phiên.' });
  session.revokedAt = new Date();
  await req.user.save();
  res.json({ message: 'Đã thu hồi phiên đăng nhập.' });
}));

router.post('/passkeys/register/options', requireAuth, asyncHandler(async (req, res) => {
  const options = await generateRegistrationOptions({
    rpName: env.rpName,
    rpID: env.rpId,
    userName: req.user.phone,
    userDisplayName: req.user.displayName,
    attestationType: 'none',
    excludeCredentials: req.user.passkeys.map((passkey) => ({
      id: passkey.credentialId,
      transports: passkey.transports
    })),
    authenticatorSelection: {
      residentKey: 'preferred',
      userVerification: 'required',
      authenticatorAttachment: 'platform'
    }
  });
  req.user.webauthnChallenge = options.challenge;
  await req.user.save();
  res.json(options);
}));

router.post('/passkeys/register/verify', requireAuth, asyncHandler(async (req, res) => {
  const verification = await verifyRegistrationResponse({
    response: req.body.response,
    expectedChallenge: req.user.webauthnChallenge,
    expectedOrigin: env.expectedOrigin,
    expectedRPID: env.rpId
  });
  if (!verification.verified || !verification.registrationInfo) return res.status(400).json({ verified: false });

  const { credential, credentialDeviceType, credentialBackedUp } = verification.registrationInfo;
  req.user.passkeys.push({
    credentialId: credential.id,
    publicKey: Buffer.from(credential.publicKey),
    counter: credential.counter,
    transports: credential.transports || req.body.response?.response?.transports || [],
    deviceType: credentialDeviceType,
    backedUp: credentialBackedUp,
    name: req.body.name || 'FaceID / Fingerprint'
  });
  req.user.webauthnChallenge = undefined;
  await req.user.save();
  res.json({ verified: true });
}));

router.post('/passkeys/login/options', asyncHandler(async (req, res) => {
  const phone = normalizePhone(req.body.phone);
  const user = await User.findOne({ phone });
  if (!user || user.passkeys.length === 0) return res.status(404).json({ message: 'Tài khoản chưa đăng ký sinh trắc học.' });
  const options = await generateAuthenticationOptions({
    rpID: env.rpId,
    userVerification: 'required',
    allowCredentials: user.passkeys.map((passkey) => ({ id: passkey.credentialId, transports: passkey.transports }))
  });
  user.webauthnChallenge = options.challenge;
  await user.save();
  res.json(options);
}));

router.post('/passkeys/login/verify', asyncHandler(async (req, res) => {
  const phone = normalizePhone(req.body.phone);
  const user = await User.findOne({ phone });
  const passkey = user?.passkeys.find((item) => item.credentialId === req.body.response?.id);
  if (!user || !passkey) return res.status(404).json({ message: 'Không tìm thấy khóa đăng nhập.' });

  const verification = await verifyAuthenticationResponse({
    response: req.body.response,
    expectedChallenge: user.webauthnChallenge,
    expectedOrigin: env.expectedOrigin,
    expectedRPID: env.rpId,
    credential: {
      id: passkey.credentialId,
      publicKey: new Uint8Array(passkey.publicKey),
      counter: passkey.counter,
      transports: passkey.transports
    }
  });
  if (!verification.verified) return res.status(401).json({ verified: false });
  passkey.counter = verification.authenticationInfo.newCounter;
  user.webauthnChallenge = undefined;
  await user.save();
  const result = await createSession(user, req, req.body.device || {});
  res.json({ verified: true, ...result });
}));

export default router;
