export function hasEmailOtpConfigured() {
  const gmailUser = String(process.env.GMAIL_USER || process.env.EMAIL_USER || process.env.SMTP_USER || '').trim();
  const gmailPass = String(process.env.GMAIL_APP_PASSWORD || process.env.EMAIL_PASS || process.env.SMTP_PASS || '').trim();
  return Boolean(gmailUser && gmailPass);
}

export async function sendOtpEmail(email, code, purpose = 'login') {
  const to = String(email || '').trim().toLowerCase();

  if (!to) {
    throw Object.assign(new Error('Missing email receiver.'), { status: 400 });
  }

  const gmailUser = String(process.env.GMAIL_USER || process.env.EMAIL_USER || process.env.SMTP_USER || '').trim();
  const gmailPass = String(process.env.GMAIL_APP_PASSWORD || process.env.EMAIL_PASS || process.env.SMTP_PASS || '').trim();
  const from = String(process.env.EMAIL_FROM || (gmailUser ? `Legatalk Connect <${gmailUser}>` : '')).trim();

  if (!gmailUser || !gmailPass) {
    throw Object.assign(
      new Error('Gmail OTP chua duoc cau hinh. Can GMAIL_USER va GMAIL_APP_PASSWORD trong .env.'),
      { status: 500 },
    );
  }

  const subjectMap = {
    register: 'Ma OTP dang ky Legatalk Connect',
    login: 'Ma OTP dang nhap Legatalk Connect',
    reset: 'Ma OTP dat lai mat khau Legatalk Connect',
  };

  const subject = subjectMap[purpose] || 'Ma OTP Legatalk Connect';
  const text = `Ma OTP cua ban la ${code}. Ma co hieu luc trong thoi gian ngan. Khong chia se ma nay cho bat ky ai.`;
  const html = `
    <div style="font-family:Arial,sans-serif;line-height:1.5;color:#111827">
      <h2 style="margin:0 0 12px">Legatalk Connect</h2>
      <p>Ma OTP cua ban:</p>
      <div style="font-size:30px;font-weight:800;letter-spacing:6px;background:#f1f5f9;padding:14px 18px;border-radius:14px;display:inline-block">${code}</div>
      <p style="color:#64748b">Khong chia se ma nay cho bat ky ai.</p>
    </div>
  `;

  const nodemailer = await import('nodemailer');

  const transporter = nodemailer.default.createTransport({
    service: 'gmail',
    auth: {
      user: gmailUser,
      pass: gmailPass,
    },
  });

  await transporter.sendMail({
    from,
    to,
    subject,
    text,
    html,
  });

  console.log(`[GMAIL OTP SENT] to=${to} purpose=${purpose}`);
  return { channel: 'email' };
}
