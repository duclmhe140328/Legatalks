NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/nexora_connect

# Local: cho phép Vite trên máy này và các thiết bị trong LAN.
# Production: điền domain HTTPS thật, có thể nhiều domain phân cách bằng dấu phẩy.
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_SERVER_URL=http://localhost:4000

# Để trống sẽ lưu bền vững tại %USERPROFILE%\.nexora-connect\uploads
UPLOAD_DIR=
MIROTALK_BRO_PUBLIC_URL=https://bro.mirotalk.com
MIROTALK_BRO_API_URL=https://bro.mirotalk.com
MIROTALK_BRO_API_KEY=mirotalkbro_default_secret
JWT_ACCESS_SECRET=replace-this-access-secret
JWT_REFRESH_SECRET=replace-this-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30
OTP_PROVIDER=email
OTP_TTL_MINUTES=5
OTP_DEV_CODE=123456
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
RP_ID=localhost
RP_NAME=Nexora Connect
EXPECTED_ORIGIN=http://localhost:5173
WEBHOOK_SIGNING_SECRET=replace-this-webhook-secret

# WebRTC: STUN đủ cho local/cùng mạng; production bắt buộc TURN để đi qua NAT/firewall.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_URLS=turn:localhost:3478
TURN_USERNAME=nexora
TURN_CREDENTIAL=nexora-turn-secret

FCM_SERVICE_ACCOUNT_JSON=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
APNS_PRODUCTION=false
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=replace-this-payment-secret

# Jitsi meeting integration
JITSI_DOMAIN=meet.jit.si
# Optional if you use JaaS/self-host JWT auth
JITSI_JWT=
JITSI_LANGUAGE=vi
GMAIL_USER=ducvt24@gmail.com
GMAIL_APP_PASSWORD=hkku rafh hdqh rwac
EMAIL_FROM=Legatalk Connect <ducvt24@gmail.com>

# PWA Web Push notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nexora.local
